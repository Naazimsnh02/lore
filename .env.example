# =============================================================================
# LORE — Environment Configuration Reference
# =============================================================================
#
# Copy this file to .env (git-ignored) and fill in your values.
# Cloud Run: set these as service environment variables.
#            Use Secret Manager for anything marked SECRET.
#
# Convention:
#   - <required>  — service fails without it
#   - <optional>  — has a safe default
#   - SECRET      — never commit the real value; use Secret Manager in prod
#   - TODO        — you must look this up / create it before running
# =============================================================================


# =============================================================================
# 1. GOOGLE CLOUD PROJECT
# =============================================================================

GCP_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1


# =============================================================================
# 2. AUTHENTICATION — Application Default Credentials (ADC)
# =============================================================================
#
# Cloud Run: service account is attached automatically — leave this unset.
# Local dev option A (recommended):
#   gcloud auth application-default login
# Local dev option B (service account key):
#   gcloud iam service-accounts keys create sa-key.json \
#       --iam-account=lore-backend@YOUR_PROJECT.iam.gserviceaccount.com
#   Then set the path below. The .json file is git-ignored.
#
# <optional — only needed locally if not using gcloud ADC>
GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json


# =============================================================================
# 3. GEMINI API KEY (local dev / Google AI Studio)
# =============================================================================
#
# Used by google-genai SDK when NOT running on Vertex AI.
# Get from: https://aistudio.google.com/apikey
# In production on Cloud Run, leave unset — ADC + Vertex AI is used instead.
# SECRET / TODO
GEMINI_API_KEY=your-gemini-api-key-from-ai-studio

# Set to "true" to route all google-genai calls through Vertex AI (production).
# Set to "false" to use GEMINI_API_KEY directly (local dev).
GOOGLE_GENAI_USE_VERTEXAI=false


# =============================================================================
# 4. FIREBASE / IDENTITY PLATFORM
# =============================================================================

# Firebase project ID (same as GCP project for LORE)
FIREBASE_PROJECT_ID=your-gcp-project-id

# Firebase Web API Key — Flutter anonymous sign-in
# Find: Firebase Console → Project Settings → General → Web API Key
# SECRET
FIREBASE_WEB_API_KEY=AIzaSy-your-firebase-web-api-key

# Firebase Android App ID
# Find: Firebase Console → Project Settings → Your apps → Android app
FIREBASE_ANDROID_APP_ID=1:000000000000:android:your-android-app-id

# Firebase iOS App ID
# Find: Firebase Console → Project Settings → Your apps → iOS app
FIREBASE_IOS_APP_ID=1:000000000000:ios:your-ios-app-id

# Firebase Messaging Sender ID
# Find: Firebase Console → Project Settings → General → Sender ID
FIREBASE_MESSAGING_SENDER_ID=000000000000


# =============================================================================
# 5. WEBSOCKET GATEWAY (Cloud Run service)
# =============================================================================

# Local dev only — Cloud Run injects PORT automatically
PORT=8080

# DEBUG for local dev, INFO for staging/prod
LOG_LEVEL=DEBUG

# true = accept mock_<user_id> tokens (dev/test only — NEVER true in prod)
LORE_MOCK_AUTH=true

# Local: ws://localhost:8080   After deploy: wss://your-service-HASH-uc.a.run.app
# TODO: update after first Cloud Run deployment
WEBSOCKET_GATEWAY_URL=ws://localhost:8080


# =============================================================================
# 6. FIRESTORE (Session Memory)
# =============================================================================

FIRESTORE_DATABASE=(default)


# =============================================================================
# 7. CLOUD STORAGE (Media Store)
# =============================================================================

# Bucket name only — no gs:// prefix
# TODO: check the bucket created by Terraform or GCP Console
GCS_MEDIA_BUCKET=lore-media-your-project-id

GCS_USER_QUOTA_BYTES=10737418240
GCS_SIGNED_URL_EXPIRY_MINUTES=60
GCS_RETENTION_DAYS=90


# =============================================================================
# 8. CLOUD PUB/SUB
# =============================================================================

PUBSUB_NARRATION_TOPIC=narration-tasks
PUBSUB_VIDEO_TOPIC=video-tasks
PUBSUB_ILLUSTRATION_TOPIC=illustration-tasks
PUBSUB_SEARCH_TOPIC=search-tasks


# =============================================================================
# 9. GOOGLE PLACES API (Location Recognizer)
# =============================================================================

# Enable "Places API (New)" in GCP Console → APIs & Services → Enable APIs
# Then create a key: APIs & Services → Credentials → Create API Key
# Restrict the key to "Places API (New)" only
# SECRET / TODO
GOOGLE_PLACES_API_KEY=your-places-api-key


# =============================================================================
# 10. AI MODELS
# =============================================================================

# Vision + orchestration (Gemini 3 Flash Preview)
GEMINI_VISION_MODEL=gemini-3-flash-preview
GEMINI_ORCHESTRATOR_MODEL=gemini-3-flash-preview

# Live API — real-time native audio narration
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Video generation (Veo 3.1)
VEO_MODEL=veo-3.1-generate-preview

# Illustration generation — Nano Banana 2
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview


# =============================================================================
# 11. RATE LIMITING
# =============================================================================

RATE_LIMIT_GEMINI_RPM=10
RATE_LIMIT_VEO_RPD=20
RATE_LIMIT_ILLUSTRATION_RPM=30
RATE_LIMIT_SEARCH_RPM=60


# =============================================================================
# 12. FLUTTER MOBILE CLIENT
# =============================================================================
#
# Flutter does NOT read .env files. Pass values at build time:
#
#   flutter run \
#     --dart-define=WEBSOCKET_GATEWAY_URL=wss://... \
#     --dart-define=GCP_PROJECT_ID=your-project
#
# firebase_options.dart is generated by FlutterFire CLI — no env vars needed.
# =============================================================================
