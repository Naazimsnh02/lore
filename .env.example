# =============================================================================
# LORE — Environment Configuration Reference
# =============================================================================
#
# Copy this file to .env (git-ignored) and fill in your values.
# Cloud Run: set these as service environment variables.
#            Use Secret Manager for anything marked SECRET.
#
# Active services:
#   gemini_live_proxy  :8090  — WebSocket proxy to Gemini Live API
#   nano_illustrator   :8091  — HTTP image generation
#   veo_generator      :8092  — HTTP video generation
# =============================================================================


# =============================================================================
# 1. GOOGLE CLOUD PROJECT
# =============================================================================

GCP_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1


# =============================================================================
# 2. AUTHENTICATION — Application Default Credentials (ADC)
# =============================================================================
#
# Cloud Run: service account is attached automatically — leave this unset.
# Local dev (recommended):
#   gcloud auth application-default login
#
# <optional — only needed locally if not using gcloud ADC>
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json


# =============================================================================
# 3. GEMINI API KEY (local dev / Google AI Studio)
# =============================================================================
#
# Used when GOOGLE_GENAI_USE_VERTEXAI=false (local dev).
# Get from: https://aistudio.google.com/apikey
# In production on Cloud Run, leave unset — ADC + Vertex AI is used instead.
# SECRET / TODO
GEMINI_API_KEY=your-gemini-api-key-from-ai-studio

# Set to "true" to route all google-genai calls through Vertex AI (production).
# Set to "false" to use GEMINI_API_KEY directly (local dev).
GOOGLE_GENAI_USE_VERTEXAI=false


# =============================================================================
# 4. SERVER SETTINGS
# =============================================================================

# DEBUG for local dev, INFO for production
LOG_LEVEL=DEBUG


# =============================================================================
# 5. GOOGLE PLACES & MAPS API
# =============================================================================

# Enable "Places API (New)" in GCP Console → APIs & Services → Enable APIs
# SECRET / TODO
GOOGLE_PLACES_API_KEY=your-places-api-key

# Enable "Maps SDK for Android/iOS" and "Directions API" in GCP Console
# Also passed to Flutter at build time via dart-defines.json
# SECRET / TODO
GOOGLE_MAPS_API_KEY=your-maps-api-key


# =============================================================================
# 6. AI MODELS
# =============================================================================

# Live API — real-time native audio narration
# Vertex AI (GOOGLE_GENAI_USE_VERTEXAI=true):  gemini-live-2.5-flash-native-audio
# AI Studio  (GOOGLE_GENAI_USE_VERTEXAI=false): gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio

# Video generation (Veo 3.1)
VEO_MODEL=veo-3.1-generate-preview
# Resolution: "720p" (fastest), "1080p" (default), "4k" (slowest/priciest)
VEO_RESOLUTION=720p
# Duration in seconds: 4 | 5 | 6 | 8 — shorter = faster generation
VEO_DURATION_SECONDS=5

# Illustration generation
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# JPEG compression quality (1-100). Lower = smaller payload, faster transfer.
IMAGE_OUTPUT_QUALITY=85


# =============================================================================
# 7. FLUTTER MOBILE CLIENT
# =============================================================================
#
# Flutter does NOT read .env files. Pass values at build time via dart-defines.json:
#
#   flutter run --dart-define-from-file=dart-defines.json
#
# Required keys in dart-defines.json:
#   GEMINI_PROXY_URL     — ws://<host>:8090  (local) or wss://... (production)
#   GOOGLE_MAPS_API_KEY  — your Maps API key
#   GCP_PROJECT_ID       — only for Vertex AI / production
# =============================================================================
